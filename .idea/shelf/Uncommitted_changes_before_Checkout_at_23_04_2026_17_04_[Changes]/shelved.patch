<+><!DOCTYPE html>\r\n<html lang=\"tr\">\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>YANKI – Acil İletişim Ağı İzleme Merkezi</title>\r\n  <style>\r\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\r\n\r\n    body {\r\n      font-family: Arial, Helvetica, sans-serif;\r\n      font-size: 13px;\r\n      background: #d6dce6;\r\n      color: #111;\r\n    }\r\n\r\n    /* ── ÜST HEADER ── */\r\n    #top-bar {\r\n      background: #002060;\r\n      color: #fff;\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 16px;\r\n      padding: 8px 20px;\r\n      border-bottom: 3px solid #e8a000;\r\n    }\r\n    #top-bar .logo {\r\n      font-size: 36px;\r\n      font-weight: 900;\r\n      letter-spacing: -1px;\r\n      color: #e8c000;\r\n      line-height: 1;\r\n    }\r\n    #top-bar .titles { flex: 1; }\r\n    #top-bar .titles h1 {\r\n      font-size: 16px;\r\n      font-weight: 700;\r\n      text-transform: uppercase;\r\n      letter-spacing: .5px;\r\n      line-height: 1.3;\r\n    }\r\n    #top-bar .titles p {\r\n      font-size: 11px;\r\n      color: #afc8e8;\r\n      margin-top: 2px;\r\n      text-transform: uppercase;\r\n      letter-spacing: .8px;\r\n    }\r\n    #top-bar .clock {\r\n      text-align: right;\r\n      font-size: 11px;\r\n      color: #afc8e8;\r\n      line-height: 1.8;\r\n    }\r\n    #top-bar .clock span {\r\n      display: block;\r\n      font-size: 22px;\r\n      font-weight: 700;\r\n      color: #fff;\r\n      font-variant-numeric: tabular-nums;\r\n    }\r\n\r\n    /* ── NAVİGASYON ── */\r\n    nav {\r\n      background: #003580;\r\n      display: flex;\r\n      gap: 1px;\r\n    }\r\n    nav a {\r\n      display: block;\r\n      padding: 7px 16px;\r\n      color: #c8d8f0;\r\n      text-decoration: none;\r\n      font-size: 12px;\r\n      font-weight: 700;\r\n      text-transform: uppercase;\r\n      letter-spacing: .4px;\r\n      transition: background .15s;\r\n    }\r\n    nav a:hover, nav a.active { background: #e8a000; color: #fff; }\r\n\r\n    /* ── ANA PANEL ── */\r\n    #main {\r\n      max-width: 1200px;\r\n      margin: 18px auto;\r\n      padding: 0 12px;\r\n    }\r\n\r\n    /* ── PANEL KUTU ── */\r\n    .panel {\r\n      background: #fff;\r\n      border: 1px solid #a0b0c8;\r\n      border-radius: 2px;\r\n      margin-bottom: 18px;\r\n    }\r\n    .panel-header {\r\n      background: #002060;\r\n      color: #fff;\r\n      padding: 7px 12px;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      gap: 12px;\r\n    }\r\n    .panel-header h2 {\r\n      font-size: 13px;\r\n      font-weight: 700;\r\n      text-transform: uppercase;\r\n      letter-spacing: .5px;\r\n    }\r\n    .panel-header .meta {\r\n      font-size: 11px;\r\n      color: #afc8e8;\r\n    }\r\n    .live-dot {\r\n      display: inline-block;\r\n      width: 8px; height: 8px;\r\n      background: #ff4444;\r\n      border-radius: 50%;\r\n      margin-right: 6px;\r\n      animation: blink 1s infinite;\r\n    }\r\n    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }\r\n\r\n    /* ── TABLO ── */\r\n    .table-wrap { overflow-x: auto; }\r\n    table {\r\n      width: 100%;\r\n      border-collapse: collapse;\r\n    }\r\n    thead tr {\r\n      background: #003580;\r\n      color: #fff;\r\n    }\r\n    thead th {\r\n      padding: 7px 10px;\r\n      font-size: 11px;\r\n      font-weight: 700;\r\n      text-transform: uppercase;\r\n      letter-spacing: .5px;\r\n      white-space: nowrap;\r\n      border-right: 1px solid #1a4090;\r\n      text-align: center;\r\n    }\r\n    thead th:last-child { border-right: none; }\r\n    tbody tr:nth-child(even) { background: #edf2fb; }\r\n    tbody tr:nth-child(odd)  { background: #fff; }\r\n    tbody tr:hover { background: #fff3cc; }\r\n    tbody td {\r\n      padding: 6px 10px;\r\n      border-bottom: 1px solid #dde4ef;\r\n      border-right: 1px solid #dde4ef;\r\n      text-align: center;\r\n      white-space: nowrap;\r\n    }\r\n    tbody td:last-child { border-right: none; }\r\n    tbody td.name-col { text-align: left; font-weight: 600; white-space: normal; }\r\n\r\n    /* Durum renkleri */\r\n    .badge {\r\n      display: inline-block;\r\n      padding: 2px 8px;\r\n      border-radius: 10px;\r\n      font-size: 11px;\r\n      font-weight: 700;\r\n      letter-spacing: .3px;\r\n      text-transform: uppercase;\r\n    }\r\n    .badge-FIRE      { background: #ff4444; color: #fff; }\r\n    .badge-INJURED   { background: #e67e00; color: #fff; }\r\n    .badge-TRAPPED   { background: #8b0000; color: #fff; }\r\n    .badge-FLOOD     { background: #1565c0; color: #fff; }\r\n    .badge-SAFE      { background: #2e7d32; color: #fff; }\r\n    .badge-HELP      { background: #6a0dad; color: #fff; }\r\n    .badge-UNKNOWN   { background: #757575; color: #fff; }\r\n    .badge-default   { background: #004d99; color: #fff; }\r\n\r\n    /* Yükleniyor */\r\n    #loading-row td {\r\n      padding: 30px;\r\n      color: #666;\r\n      font-style: italic;\r\n      text-align: center;\r\n    }\r\n\r\n    /* ── DURUM ÇUBUĞU ── */\r\n    #status-bar {\r\n      background: #002060;\r\n      color: #afc8e8;\r\n      font-size: 11px;\r\n      padding: 5px 20px;\r\n      display: flex;\r\n      justify-content: space-between;\r\n    }\r\n\r\n    /* ── KURULUM UYARISI ── */\r\n    #config-warning {\r\n      background: #fff3cd;\r\n      border: 1px solid #e8a000;\r\n      border-radius: 4px;\r\n      padding: 14px 18px;\r\n      margin-bottom: 14px;\r\n      font-size: 12px;\r\n      line-height: 1.7;\r\n      display: none;\r\n    }\r\n    #config-warning strong { color: #002060; }\r\n  </style>\r\n</head>\r\n<body>\r\n\r\n<!-- ── ÜST HEADER ── -->\r\n<div id=\"top-bar\">\r\n  <div class=\"logo\">⚡YANKI</div>\r\n  <div class=\"titles\">\r\n    <h1>Merkeziyetsiz Afet İletişim Ağı – Canlı İzleme Merkezi</h1>\r\n    <p>Boğaziçi Üniversitesi · Kandilli Rasathanesi ve Deprem Araştırma Enstitüsü tarzı tasarım</p>\r\n  </div>\r\n  <div class=\"clock\">\r\n    <span id=\"clock-time\">--:--:--</span>\r\n    <div id=\"clock-date\">-- -- ----</div>\r\n    <div>Türkiye Saati (TRT / UTC+3)</div>\r\n  </div>\r\n</div>\r\n\r\n<!-- ── NAVİGASYON ── -->\r\n<nav>\r\n  <a href=\"#\" class=\"active\">Canlı Veriler</a>\r\n  <a href=\"#\">Acil Sinyaller</a>\r\n  <a href=\"#\">Harita</a>\r\n  <a href=\"#\">Hakkında</a>\r\n</nav>\r\n\r\n<!-- ── ANA İÇERİK ── -->\r\n<div id=\"main\">\r\n\r\n  <!-- Yapılandırma uyarısı (Firebase config girilmemişse gösterilir) -->\r\n  <div id=\"config-warning\">\r\n    ⚠\uFE0F <strong>Kurulum gerekli:</strong> Sayfanın çalışabilmesi için aşağıdaki bölümde\r\n    Firebase projenizin yapılandırma bilgilerini <code>index.html</code> dosyasına girmeniz gerekiyor.<br>\r\n    Firebase Console → Proje Ayarları → Web Uygulaması → <em>firebaseConfig</em> nesnesini kopyalayın.\r\n  </div>\r\n\r\n  <!-- Ana veri tablosu -->\r\n  <div class=\"panel\">\r\n    <div class=\"panel-header\">\r\n      <h2>\r\n        <span class=\"live-dot\"></span>\r\n        Son Acil İletişim Kayıtları\r\n      </h2>\r\n      <span class=\"meta\">\r\n        Son güncelleme: <strong id=\"last-update\">–</strong> &nbsp;|&nbsp;\r\n        Toplam kayıt: <strong id=\"record-count\">0</strong>\r\n      </span>\r\n    </div>\r\n\r\n    <div class=\"table-wrap\">\r\n      <table>\r\n        <thead>\r\n          <tr>\r\n            <th>Tarih</th>\r\n            <th>Saat</th>\r\n            <th>Enlem (K)</th>\r\n            <th>Boylam (D)</th>\r\n            <th style=\"text-align:left; min-width:160px;\">İsim Soyisim</th>\r\n            <th>Durum</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody id=\"data-tbody\">\r\n          <tr id=\"loading-row\">\r\n            <td colspan=\"6\">Veriler yükleniyor…</td>\r\n          </tr>\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n  </div>\r\n\r\n</div>\r\n\r\n<!-- ── DURUM ÇUBUĞU ── -->\r\n<div id=\"status-bar\">\r\n  <span>YANKI Mesh Network © 2025 – Afet anında kesintisiz iletişim</span>\r\n  <span id=\"conn-status\">\uD83D\uDD34 Bağlantı bekleniyor…</span>\r\n</div>\r\n\r\n\r\n<!-- ════════════════════════════════════════════════\r\n     FİREBASE YAPILANDIRMASI\r\n     Firebase Console → Proje Ayarları → Uygulamalar → Web\r\n     bölümünden aldığınız firebaseConfig nesnesini buraya yapıştırın.\r\n     ════════════════════════════════════════════════ -->\r\n<script type=\"module\">\r\n  import { initializeApp }   from \"https://www.gstatic.com/firebasejs/11.7.1/firebase-app.js\";\r\n  import { getFirestore, collection, query, orderBy, limit, onSnapshot, getDocs }\r\n    from \"https://www.gstatic.com/firebasejs/11.7.1/firebase-firestore.js\";\r\n\r\n  // ▼▼▼ BU BÖLÜMü KENDİ FİREBASE BİLGİLERİNİZLE DEĞİŞTİRİN ▼▼▼\r\n  const firebaseConfig = {\r\n  };\r\n  // ▲▲▲ YAPILANDIRMA SONU ▲▲▲\r\n\r\n  // Placeholder kontrolü\r\n    document.getElementById(\"config-warning\").style.display = \"block\";\r\n    document.getElementById(\"loading-row\").querySelector(\"td\").textContent =\r\n      \"⚠\uFE0F Firebase yapılandırması eksik. Lütfen index.html dosyasını düzenleyin.\";\r\n    document.getElementById(\"conn-status\").textContent = \"⚠\uFE0F Yapılandırma eksik\";\r\n  } else {\r\n    startApp(firebaseConfig);\r\n  }\r\n\r\n  function startApp(config) {\r\n    const app = initializeApp(config);\r\n    const db  = getFirestore(app);\r\n\r\n    let usersMap = {};\r\n\r\n    // Tüm kullanıcıları bir kez çek (isim arama için)\r\n    async function loadUsers() {\r\n      try {\r\n        const snap = await getDocs(collection(db, \"users\"));\r\n        snap.forEach(doc => { usersMap[doc.id] = doc.data(); });\r\n      } catch (e) {\r\n        console.warn(\"Kullanıcı listesi alınamadı:\", e.message);\r\n      }\r\n    }\r\n\r\n    function durumuBilgisi(tip) {\r\n      const map = {\r\n        FIRE:    { tr: \"YANGIN\",    cls: \"badge-FIRE\"    },\r\n        INJURED: { tr: \"YARALANDI\", cls: \"badge-INJURED\" },\r\n        TRAPPED: { tr: \"MAHSUR\",   cls: \"badge-TRAPPED\" },\r\n        FLOOD:   { tr: \"SEL\",       cls: \"badge-FLOOD\"   },\r\n        SAFE:    { tr: \"GÜVENDE\",   cls: \"badge-SAFE\"    },\r\n        HELP:    { tr: \"YARDIM\",    cls: \"badge-HELP\"    },\r\n      };\r\n      const key = (tip || \"\").toUpperCase();\r\n      return map[key] || { tr: tip || \"BİLİNMİYOR\", cls: \"badge-default\" };\r\n    }\r\n\r\n    function formatDate(ts) {\r\n      if (!ts) return { tarih: \"–\", saat: \"–\" };\r\n      const d = ts.toDate ? ts.toDate() : new Date(ts);\r\n      const tarih = d.toLocaleDateString(\"tr-TR\", { day:\"2-digit\", month:\"2-digit\", year:\"numeric\" });\r\n      const saat  = d.toLocaleTimeString(\"tr-TR\", { hour:\"2-digit\", minute:\"2-digit\", second:\"2-digit\" });\r\n      return { tarih, saat };\r\n    }\r\n\r\n    function renderTable(docs) {\r\n      const tbody = document.getElementById(\"data-tbody\");\r\n      tbody.innerHTML = \"\";\r\n\r\n      if (docs.length === 0) {\r\n        tbody.innerHTML = `<tr id=\"loading-row\"><td colspan=\"6\">Henüz kayıt yok.</td></tr>`;\r\n        return;\r\n      }\r\n\r\n      docs.forEach(docSnap => {\r\n        const d = docSnap.data();\r\n        const user = usersMap[d.user_id] || {};\r\n        const isimSoyisim = user.user_name || d.user_id || \"–\";\r\n        const { tarih, saat } = formatDate(d.created_at);\r\n        const lat = d.location?.latitude  != null ? d.location.latitude.toFixed(4)  : \"–\";\r\n        const lon = d.location?.longitude != null ? d.location.longitude.toFixed(4) : \"–\";\r\n        const durum = durumuBilgisi(d.emergency_type);\r\n\r\n        const tr = document.createElement(\"tr\");\r\n        tr.innerHTML = `\r\n          <td>${tarih}</td>\r\n          <td>${saat}</td>\r\n          <td>${lat}</td>\r\n          <td>${lon}</td>\r\n          <td class=\"name-col\">${isimSoyisim}</td>\r\n          <td><span class=\"badge ${durum.cls}\">${durum.tr}</span></td>\r\n        `;\r\n        tbody.appendChild(tr);\r\n      });\r\n\r\n      document.getElementById(\"record-count\").textContent = docs.length;\r\n      document.getElementById(\"last-update\").textContent =\r\n        new Date().toLocaleTimeString(\"tr-TR\");\r\n    }\r\n\r\n    async function init() {\r\n      await loadUsers();\r\n\r\n      const q = query(\r\n        collection(db, \"emergency_signals\"),\r\n        orderBy(\"created_at\", \"desc\"),\r\n        limit(100)\r\n      );\r\n\r\n      onSnapshot(q,\r\n        (snapshot) => {\r\n          renderTable(snapshot.docs);\r\n          document.getElementById(\"conn-status\").textContent = \"\uD83D\uDFE2 Canlı bağlı\";\r\n        },\r\n        (err) => {\r\n          console.error(\"Firestore hatası:\", err);\r\n          document.getElementById(\"conn-status\").textContent = \"\uD83D\uDD34 Bağlantı hatası: \" + err.message;\r\n        }\r\n      );\r\n    }\r\n\r\n    init();\r\n  }\r\n</script>\r\n\r\n<!-- Saat / Tarih güncelleme -->\r\n<script>\r\n  function updateClock() {\r\n    const now = new Date();\r\n    document.getElementById(\"clock-time\").textContent =\r\n      now.toLocaleTimeString(\"tr-TR\", { hour:\"2-digit\", minute:\"2-digit\", second:\"2-digit\" });\r\n    document.getElementById(\"clock-date\").textContent =\r\n      now.toLocaleDateString(\"tr-TR\", { day:\"2-digit\", month:\"long\", year:\"numeric\" });\r\n  }\r\n  updateClock();\r\n  setInterval(updateClock, 1000);\r\n</script>\r\n\r\n</body>\r\n</html>\r\n
